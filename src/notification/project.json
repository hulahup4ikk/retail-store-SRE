{
  "name": "notification",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "src/notification",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node src/server.js"
      }
    },
    "container": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t retail-store-sample-notification:latest .",
        "cwd": "src/notification"
      }
    }
  },
  "tags": ["service", "chart", "sample"]
}
